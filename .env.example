# ==============================================================================
# Phronel AI Agent - Environment Configuration Template (.env.example)
# ==============================================================================
# このファイルを `.env` としてコピーし、環境に合わせて値を設定してください。
# `.env` ファイルはローカルの秘密キー等を含むため、Gitコミットの対象外に設定されています。
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. システム環境・パスの設定 (System Paths & Environment)
# ------------------------------------------------------------------------------
# SQLite データベースファイルの保存先パス
# 未指定時のデフォルト: phronel_agent.db
PHRONEL_DB_PATH=./phronel_agent.db

# ChromaDB (ベクトルストア) の永続化ディレクトリパス
# 未指定時のデフォルト: ./chroma_db
PHRONEL_CHROMA_DIR=./chroma_db

# ------------------------------------------------------------------------------
# 2. AI モデル・プロンプトの設定 (AI Model & Optimization)
# ------------------------------------------------------------------------------
# 推論に使用する Google Gemini のデフォルトモデル名
# 未指定時のデフォルト: gemini-2.5-flash
PHRONEL_LLM_MODEL=gemini-2.5-flash

# DSPy Optimizer で自動生成された最適Few-Shotプロンプトの読み込み/保存パス
# 未指定時のデフォルト: phronel_ai_agent/core/optimized_creator.json
PHRONEL_OPTIMIZED_PROMPT_PATH=phronel_ai_agent/core/optimized_creator.json

# ログの保存ディレクトリパス
PHRONEL_LLM_LOG_DIR=logs/llm

# ------------------------------------------------------------------------------
# 3. エージェントの動作設定 (Operation Modes)
# ------------------------------------------------------------------------------
# エージェントの実行モード (manual / semi-auto / auto / dry-run)
#   - manual: すべてCLI/TUIからの手動操作
#   - semi-auto: 自動で投稿案作成まで行い、投稿はユーザーの承認待ち
#   - auto: 情報収集・戦略立案からXへの投稿までを全自動で定期実行
#   - dry-run: X APIを叩かず、シミュレーションログをDBに記録
# 未指定時のデフォルト: manual
PHRONEL_EXECUTION_MODE=manual

# 定期実行 (observe) を行う際に対象とするターゲットキーワード
# 未指定時のデフォルト: AIエージェント
PHRONEL_OBSERVE_KEYWORD=AI エージェント

# ------------------------------------------------------------------------------
# 4. APIキー・認証クレデンシャル (API Credentials)
# ------------------------------------------------------------------------------
# Google Gemini API キー
PHRONEL_GEMINI_API_KEY=AIzaSy...

# X (Twitter) API OAuth 2.0 / 1.1 認証情報
PHRONEL_X_BEARER_TOKEN=AAAAAAAAAAAAAAAAAAAAA...
PHRONEL_X_API_KEY=your_consumer_key_here
PHRONEL_X_API_SECRET=your_consumer_secret_here
PHRONEL_X_ACCESS_TOKEN=your_access_token_here
PHRONEL_X_ACCESS_TOKEN_SECRET=your_access_token_secret_here
